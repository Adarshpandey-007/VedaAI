PORT=5000
NODE_ENV=development

# Gemini API Key (Required for AI generation)
# Get a key from https://aistudio.google.com
GEMINI_API_KEY=

# MongoDB URI (Optional)
# If left empty, backend falls back automatically to local file-based database.
MONGODB_URI=

# Redis configuration (Optional)
# If left empty, backend falls back automatically to in-memory task runner.
REDIS_HOST=localhost
REDIS_PORT=6379
